{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@figma/plugin-typings"],
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src/code/**/*.ts", "src/shared/**/*.ts"]
}
