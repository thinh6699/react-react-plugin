{
  "name": "figma-react-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,code -c cyan,magenta \"vite\" \"npm run build:code -- --watch\"",
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "tsc -b && vite build",
    "build:code": "node scripts/build-code.mjs",
    "watch": "concurrently -n ui,code -c cyan,magenta \"vite build --watch\" \"node scripts/build-code.mjs --watch\"",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react": "^19.2.7",
    "react-colorful": "^5.8.0",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.130.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
